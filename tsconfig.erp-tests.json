{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "tests/erp-readonly.test.ts",
    "services/erpAudit.ts",
    "services/erpCalculations.ts",
    "services/erpComparison.ts",
    "services/erpLedger.ts",
    "services/erpMapper.ts",
    "services/erpRepairPreview.ts",
    "types.ts"
  ]
}
